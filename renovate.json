{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "timezone": "Europe/Berlin",
  "schedule": [
    "before 6am on monday"
  ],
  "prHourlyLimit": 5,
  "prConcurrentLimit": 10,
  "labels": [
    "dependencies"
  ],
  "platformAutomerge": true,
  "packageRules": [
    {
      "description": "Auto-merge patch updates",
      "matchUpdateTypes": [
        "patch"
      ],
      "automerge": true
    },
    {
      "description": "Group all Helm chart updates (non-patch)",
      "matchManagers": [
        "custom.regex"
      ],
      "matchDatasources": [
        "helm"
      ],
      "matchUpdateTypes": [
        "minor",
        "major"
      ],
      "groupName": "helm charts"
    },
    {
      "description": "Group all Docker image updates (non-patch)",
      "matchManagers": [
        "custom.regex"
      ],
      "matchDatasources": [
        "docker"
      ],
      "matchUpdateTypes": [
        "minor",
        "major"
      ],
      "groupName": "docker images"
    },
    {
      "description": "Group ARC charts together",
      "matchManagers": [
        "custom.regex"
      ],
      "matchDatasources": [
        "docker"
      ],
      "groupName": "arc",
      "matchPackageNames": [
        "/actions-runner-controller-charts/"
      ]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Match Docker images in Pulumi TypeScript files",
      "managerFilePatterns": [
        "/\\.ts$/"
      ],
      "matchStrings": [
        "image:\\s*[\"'](?<depName>[^:\"']+):(?<currentValue>[^\"']+)[\"']"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Match Docker images with separate repository and tag fields",
      "managerFilePatterns": [
        "/\\.ts$/"
      ],
      "matchStrings": [
        "repository:\\s*[\"'](?<depName>[^\"']+)[\"'][,\\s]*\\n\\s*tag:\\s*[\"'](?<currentValue>[^\"']+)[\"']"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Match Helm chart versions (Chart API with fetchOpts)",
      "managerFilePatterns": [
        "/\\.ts$/"
      ],
      "matchStrings": [
        "chart:\\s*[\"'](?<depName>[^\"']+)[\"'][\\s\\S]*?version:\\s*[\"'](?<currentValue>[^\"']+)[\"'][\\s\\S]*?fetchOpts:\\s*\\{[\\s\\S]*?repo:\\s*[\"'](?<registryUrl>[^\"']+)[\"']",
        "chart:\\s*[\"'](?<depName>[^\"']+)[\"'][\\s\\S]*?fetchOpts:\\s*\\{[\\s\\S]*?repo:\\s*[\"'](?<registryUrl>[^\"']+)[\"'][\\s\\S]*?\\}[\\s\\S]*?version:\\s*[\"'](?<currentValue>[^\"']+)[\"']"
      ],
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "description": "Match Helm chart versions (Release API with repositoryOpts)",
      "managerFilePatterns": [
        "/\\.ts$/"
      ],
      "matchStrings": [
        "chart:\\s*[\"'](?<depName>[^\"']+)[\"'][\\s\\S]*?version:\\s*[\"'](?<currentValue>[^\"']+)[\"'][\\s\\S]*?repositoryOpts:\\s*\\{[\\s\\S]*?repo:\\s*[\"'](?<registryUrl>[^\"']+)[\"']"
      ],
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "description": "Match OCI Helm chart versions",
      "managerFilePatterns": [
        "/\\.ts$/"
      ],
      "matchStrings": [
        "chart:\\s*[\"']oci://(?<depName>[^\"']+)[\"'][\\s\\S]*?version:\\s*[\"'](?<currentValue>[^\"']+)[\"']"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Match PostgreSQL image version in CloudNativePG",
      "managerFilePatterns": [
        "/\\.ts$/"
      ],
      "matchStrings": [
        "imageName:\\s*[\"'](?<depName>[^:\"']+):(?<currentValue>[^\"']+)[\"']"
      ],
      "datasourceTemplate": "docker"
    }
  ]
}
